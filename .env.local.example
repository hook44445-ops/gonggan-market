# Copy this file to .env.local and fill in your credentials.

# ── Supabase (client-side) ────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Supabase (server-side, Vercel API routes only) ───────────────────────────
# Service role key — NEVER expose to the browser
# Get from: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── STEP Q: 앱스토어 심사용 SAFE_MODE ────────────────────────────────────────
# Set to "true" for App Store review: disables real payments and payouts
VITE_SAFE_MODE=false

# ── Twilio Verify ─────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: Twilio console → Account Info → Auth Token
TWILIO_AUTH_TOKEN=your_auth_token
# Get from: Twilio console → Verify → Services → your service SID
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
