# Copy this file to .env.local and fill in your credentials.

# ── Supabase (client-side) ────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Supabase (server-side, Vercel API routes only) ───────────────────────────
# Service role key — NEVER expose to the browser
# Get from: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── STEP Q: 앱스토어 심사용 SAFE_MODE ────────────────────────────────────────
# Set to "true" for App Store review: disables real payments and payouts
VITE_SAFE_MODE=false

# ── STEP 15: 카카오맵 SDK ─────────────────────────────────────────────────────
# Get from: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# Leave empty to use fallback mock map
VITE_KAKAO_MAP_KEY=

# ── Twilio Verify ─────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: Twilio console → Account Info → Auth Token
TWILIO_AUTH_TOKEN=your_auth_token
# Get from: Twilio console → Verify → Services → your service SID
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TossPayments ──────────────────────────────────────────────────────────────
# Get from: TossPayments Developers → 내 상점 → 테스트 API 키
# Only VITE_TOSS_CLIENT_KEY is safe to expose in the browser bundle.
# TOSS_SECRET_KEY must NEVER appear in frontend code — server/API route only.
VITE_TOSS_CLIENT_KEY=test_ck_YOUR_TEST_CLIENT_KEY
TOSS_SECRET_KEY=test_sk_YOUR_TEST_SECRET_KEY

# ── LLM 콘텐츠 생성 (Phase 10 · 옵트인 · 기본 OFF) ─────────────────────────────
# 관리자 콘텐츠 공장에서 voice/raw 초안을 실제 LLM 으로 생성한다. 아래 KEY 가 비어 있으면
# LLM 경로는 전혀 동작하지 않고 기존 템플릿(Mock) 을 그대로 사용한다(회귀 없음).
# ⚠️ VITE_ 변수는 브라우저 번들에 노출된다. 켤 경우 반드시 "사용 한도가 제한된" OpenRouter
#    키를 쓰고, 서버리스 함수를 추가하지 않는다(Vercel 12 functions 한도 유지). 브라우저 호출을
#    허용하는 OpenRouter 를 권장한다(Anthropic 직접 호출은 CORS/키노출로 비권장).
VITE_LLM_PROVIDER=openrouter                 # openrouter | anthropic (기본 openrouter)
VITE_LLM_API_KEY=                            # 비우면 OFF(Mock). 예) OpenRouter sk-or-...
VITE_LLM_MODEL=anthropic/claude-3.5-sonnet   # OpenRouter 모델 슬러그
# VITE_LLM_BASE_URL=                          # (선택) 기본: https://openrouter.ai/api/v1
# VITE_LLM_TIMEOUT_MS=30000                   # (선택) 요청 타임아웃
# VITE_LLM_MAX_RETRIES=2                       # (선택) 429/5xx/네트워크 재시도 횟수
