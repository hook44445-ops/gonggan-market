# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Server-only keys (never expose to the browser)
# Settings → API → Project API keys
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Settings → API → JWT Settings → JWT Secret
# Used to sign custom session tokens after Twilio OTP verification
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# Twilio Verify credentials
# console.twilio.com → Verify → Services
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_VERIFY_SERVICE_SID=YOUR_TWILIO_VERIFY_SERVICE_SID
