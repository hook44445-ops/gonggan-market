{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    {
      "source": "/lounge/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb][Oo][Tt]|[Cc]rawl|[Ss]pider|[Ss]lurp|facebookexternalhit|Facebot|WhatsApp|kakaotalk|kakaostory|[Yy]eti|Daum|Pinterest|vkShare|Embedly|Quora|W3C_Validator|ia_archiver).*"
        }
      ],
      "missing": [
        { "type": "query", "key": "app" }
      ],
      "destination": "/api/prerender?path=:path*"
    },
    { "source": "/((?!api/|naver0b2e655f5bb483edebab3e18bc7faf4712328734\\.html|naverdd7f227f04689ae77e06293315940389\\.html).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/push/dispatch", "schedule": "0 9 * * *" }
  ]
}
