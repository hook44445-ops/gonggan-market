<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      이 앱(TWA)은 광고/광고ID를 사용하지 않는다. play-services 계열 의존성이
      자동 병합할 수 있는 AD_ID 권한을 manifest merger 단계에서 제거해, Play
      Console 의 광고 ID 선언 요구를 원천 차단한다. (권한이 실제로 병합되지
      않는 경우엔 영향 없는 no-op)
    -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

    <!--
      웹푸시(FCM) 알림을 휴대폰 알림바에 표시하기 위한 권한.
      Android 13(API 33)+ 에서 알림 표시에 POST_NOTIFICATIONS 런타임 권한이 필요하다.
      알림 전송/수신은 웹앱의 service worker(firebase-messaging-sw.js)와 아래
      DelegationService(TWA 알림 위임)가 담당한다.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GongganMarket">

        <!-- TWA Launcher Activity -->
        <activity
            android:name="com.google.androidbrowserhelper.trusted.LauncherActivity"
            android:exported="true"
            android:screenOrientation="portrait">

            <!-- URL to open when the app launches -->
            <meta-data
                android:name="android.support.customtabs.trusted.DEFAULT_URL"
                android:value="@string/default_url" />

            <!--
              상태바/네비게이션바 색상 메타데이터는 androidbrowserhelper가
              getInt()로 읽어 "리소스 ID"로 사용한다(getColor(id) 호출). 따라서
              반드시 android:resource 로 선언해야 한다. android:value 로 넣으면
              해석된 색상 정수가 리소스 ID로 오인되어 Resources$NotFoundException
              으로 실행 즉시 크래시한다.
            -->
            <!-- Status bar color matching brand green -->
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR"
                android:resource="@color/colorPrimary" />
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR_DARK"
                android:resource="@color/colorPrimaryDark" />

            <!-- Navigation bar -->
            <meta-data
                android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR"
                android:resource="@color/colorPrimary" />

            <!-- Deep-link intent filter for Digital Asset Links verification -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="@string/asset_host" />
            </intent-filter>

            <!-- Launcher entry point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Digital Asset Links delegation -->
        <meta-data
            android:name="asset_statements"
            android:resource="@string/asset_statements" />

        <!--
          TWA 알림 위임 서비스. 웹앱(PWA)이 service worker 로 표시하는 웹푸시 알림을
          이 앱의 알림으로 휴대폰 알림바에 노출시킨다(Chrome 가 아닌 앱 명의 표시).
          androidbrowserhelper 의 DelegationService(=TrustedWebActivityService 확장)를
          그대로 사용하며 별도 네이티브 코드는 필요 없다.
        -->
        <service
            android:name="com.google.androidbrowserhelper.trusted.DelegationService"
            android:exported="false">
            <intent-filter>
                <action android:name="android.support.customtabs.trusted.TRUSTED_WEB_ACTIVITY_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

    </application>

</manifest>
